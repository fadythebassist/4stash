# Copy this file to .env and fill in your values
# The app runs in Mock Mode (localStorage) without these variables

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Android / Capacitor ───────────────────────────────────────────────────────
# Base URL for /api/* calls when running as a native Android/iOS app.
# In the browser (PWA) this is empty so relative paths are used.
# Set to the Firebase Hosting URL so the bundled web assets reach the real API.
VITE_API_BASE_URL=https://4stash.com

# ── Facebook / Meta ───────────────────────────────────────────────────────────
# Get from https://developers.facebook.com/apps
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here
VITE_FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ── Threads API ───────────────────────────────────────────────────────────────
# Get from https://developers.facebook.com/apps (Threads API product)
VITE_THREADS_APP_ID=your_threads_app_id_here
VITE_THREADS_APP_SECRET=your_threads_app_secret_here
VITE_THREADS_REDIRECT_URI=https://yourdomain.com/threads-oauth-callback.html
